{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo 'no-op'",
  "buildCommand": "echo 'no-op'",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/weather/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
